{
  "name": "xcode-pilot-mcp",
  "version": "1.0.0",
  "description": "MCP server for iOS/macOS development with Xcode, Simulator, and device management",
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "xcode-pilot-mcp": "./build/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-templates.js && chmod +x build/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "prepare": "husky",
    "prepublishOnly": "npm run check && npm run test && npm run build"
  },
  "keywords": [
    "mcp",
    "xcode",
    "ios",
    "swift",
    "simulator",
    "apple",
    "xcrun",
    "simctl",
    "macos",
    "xcodebuild",
    "model-context-protocol"
  ],
  "author": "Sitharaj Seenivasan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitharaj88/xcode-pilot-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/sitharaj88/xcode-pilot-mcp/issues"
  },
  "homepage": "https://github.com/sitharaj88/xcode-pilot-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.2.0",
    "vitest": "^3.1.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ]
}
